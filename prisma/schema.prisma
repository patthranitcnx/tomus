generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model Salesperson {
  id           Int         @id @default(autoincrement())
  name         String
  email        String?
  phone        String?
  invoices     Invoice[]
  commissions  Commission[]
  createdAt    DateTime    @default(now())
}

model Invoice {
  id             Int            @id @default(autoincrement())
  invoiceNumber  String         @unique
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId     Int
  salesperson    Salesperson    @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  salespersonId  Int
  total          Float
  commissionRate Float
  commissionTons Float          @default(0)
  commission     Commission?
  status         String         @default("รอชำระ")
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
}

model Commission {
  id             Int      @id @default(autoincrement())
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      Int      @unique
  salesperson    Salesperson @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  salespersonId  Int
  amount         Float
  paid           Boolean  @default(false)
  paidAt         DateTime?
}

model Purchase {
  id           Int      @id @default(autoincrement())
  itemName     String
  supplier     String?
  address      String?
  quantity     Float
  unit         String?
  unitPrice    Float
  total        Float
  purchaseDate DateTime @default(now())
  paymentDates DateTime[] @default([])
  paymentAmounts Float[] @default([])
  note         String?
  createdAt    DateTime @default(now())
}

model SaleRecord {
  id              Int      @id @default(autoincrement())
  itemName        String
  customer        String?
  customerPhone   String?
  customerAddress String?
  quantity        Float
  unit            String?
  unitPrice       Float
  total           Float
  saleDate        DateTime @default(now())
  paymentDates    DateTime[] @default([])
  paymentAmounts  Float[] @default([])
  note            String?
  createdAt       DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  amount      Float
  expenseDate DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())
}
